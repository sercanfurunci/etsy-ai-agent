# Anthropic Claude API key — required for all text/analysis stages
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API key — required for image generation (gpt-image-2)
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Image Provider ────────────────────────────────────────────────────────
# Select which image generation provider to use.
# Supported: openai, bfl, comfyui_sdxl, comfyui_flux_schnell
# Default: openai
IMAGE_PROVIDER=openai

# Alternative image API key if IMAGE_PROVIDER is not openai (optional)
# When IMAGE_PROVIDER=openai, OPENAI_API_KEY is used instead.
IMAGE_API_KEY=

# ── Black Forest Labs (BFL) ───────────────────────────────────────────────
# Required when IMAGE_PROVIDER=bfl
# Get your key at https://api.bfl.ai
BFL_API_KEY=
# Model to use (default: flux-2-pro-preview)
# Options: flux-2-pro-preview, flux-2-pro, flux-2-max, flux-kontext-pro, flux-kontext-max
BFL_MODEL=flux-2-pro-preview
# Output dimensions (must be divisible by 32, max ~2048)
BFL_WIDTH=1024
BFL_HEIGHT=1536

# Optional: path to a custom model pricing JSON file.
# Defaults to data/model_pricing.json in the project root.
# Fill in null values with real prices to enable cost calculation.
# MODEL_PRICING_PATH=

# ── ComfyUI (local, same computer) ────────────────────────────────────────
# ComfyUI must be running separately on this computer before generating images.
# This repository does NOT install ComfyUI or download model weights.
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_TIMEOUT_SECONDS=600
COMFYUI_POLL_INTERVAL_SECONDS=1.0
COMFYUI_CLIENT_ID=etsy-agent

# SDXL model (required when IMAGE_PROVIDER=comfyui_sdxl)
COMFYUI_SDXL_CHECKPOINT=your_sdxl_checkpoint.safetensors
COMFYUI_SDXL_VAE=
COMFYUI_SDXL_WIDTH=1024
COMFYUI_SDXL_HEIGHT=1536
COMFYUI_SDXL_STEPS=30
COMFYUI_SDXL_CFG=7.0
COMFYUI_SDXL_SAMPLER=euler
COMFYUI_SDXL_SCHEDULER=normal

# FLUX.1 Schnell models (required when IMAGE_PROVIDER=comfyui_flux_schnell)
COMFYUI_FLUX_UNET=your_flux_unet.safetensors
COMFYUI_FLUX_CLIP_L=clip_l.safetensors
COMFYUI_FLUX_T5XXL=t5xxl_fp16.safetensors
COMFYUI_FLUX_VAE=ae.safetensors
COMFYUI_FLUX_WIDTH=1024
COMFYUI_FLUX_HEIGHT=1536
COMFYUI_FLUX_STEPS=4
COMFYUI_FLUX_GUIDANCE=3.5

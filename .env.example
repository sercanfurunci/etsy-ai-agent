# Anthropic Claude API key — required for all text/analysis stages
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API key — required for image generation (gpt-image-2)
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Image provider selector — currently only "openai" is supported
IMAGE_PROVIDER=openai

# Alternative image API key if IMAGE_PROVIDER is not openai (optional)
# When IMAGE_PROVIDER=openai, OPENAI_API_KEY is used instead.
IMAGE_API_KEY=
